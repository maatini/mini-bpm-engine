{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.0/.schema/devbox.schema.json",
  "packages": [
    "rustup@latest",
    "gcc@latest",
    "rust-analyzer@latest",
    "nats-server@latest",
    "natscli@latest",
    "nodejs@latest"
  ],
  "env": {
    "NATS_URL": "nats://localhost:4222",
    "ENGINE_API_URL": "http://localhost:8081"
  },
  "shell": {
    "init_hook": [
      "rustup default stable 2>/dev/null",
      "echo '🦀 Rust toolchain ready: '$(rustc --version)",
      "echo '🚀 Mini BPM Workspace ready!'"
    ],
    "scripts": {
      "build": [
        "cargo build --workspace"
      ],
      "lint": [
        "cargo clippy --workspace -- -D warnings"
      ],
      "fmt": [
        "cargo fmt --all --check"
      ],
      "test": [
        "cargo test --workspace"
      ],
      "nats:up": [
        "docker compose up -d nats"
      ],
      "nats:down": [
        "docker compose down"
      ],
      "engine:run": [
        "cargo run -p engine-server"
      ],
      "engine:docker": [
        "docker compose up -d"
      ],
      "ui:dev": [
        "cd desktop-tauri && npm install && npm run tauri dev"
      ],
      "dev": [
        "echo 'Use the following commands to develop:'",
        "echo '1. Start nats & engine-server via Docker: devbox run engine:docker'",
        "echo '2. OR Start engine-server locally:        devbox run engine:run (requires devbox run nats:up)'",
        "echo '3. Start Tauri Desktop UI:                devbox run ui:dev'"
      ],
      "test:nats": [
        "devbox run nats:up",
        "sleep 2",
        "cargo test --workspace",
        "devbox run nats:down"
      ],
      "test:e2e:ui": [
        "cd desktop-tauri && npm run test:e2e"
      ],
      "test:compliance": [
        "cargo test --test bpmn_compliance"
      ]
    }
  }
}